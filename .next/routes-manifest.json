{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "/DesignStudio-EKT",
  "redirects": [
    {
      "source": "/DesignStudio-EKT/",
      "destination": "/DesignStudio-EKT",
      "basePath": false,
      "internal": true,
      "statusCode": 308,
      "regex": "^/DesignStudio-EKT/$"
    },
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [
      {
        "source": "/DesignStudio-EKT//_next/:path+",
        "destination": "/DesignStudio-EKT/_next/:path+",
        "regex": "^/DesignStudio-EKT//_next(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))(?:/)?$"
      }
    ],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/novosti/[slug]",
      "regex": "^/novosti/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/novosti/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/[slug]",
      "regex": "^/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/(?<nxtPslug>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/kontakty",
      "regex": "^/kontakty(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/kontakty(?:/)?$"
    },
    {
      "page": "/novosti",
      "regex": "^/novosti(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/novosti(?:/)?$"
    },
    {
      "page": "/o-nas",
      "regex": "^/o\\-nas(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/o\\-nas(?:/)?$"
    },
    {
      "page": "/otzyvy-o-nas",
      "regex": "^/otzyvy\\-o\\-nas(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/otzyvy\\-o\\-nas(?:/)?$"
    },
    {
      "page": "/portfolio",
      "regex": "^/portfolio(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/portfolio(?:/)?$"
    },
    {
      "page": "/services",
      "regex": "^/services(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/services(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}