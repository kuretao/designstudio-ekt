FROM node:24-alpine

WORKDIR /app

ENV NEXT_TELEMETRY_DISABLED=1

ARG NEXT_PUBLIC_API_BASE_URL=/api/v1
ARG NEXT_PUBLIC_SITE_URL=https://3dsmartdesign.ru
ARG NEXT_PUBLIC_GOOGLE_TAG_ID=
ARG GOOGLE_SITE_VERIFICATION=HlopiXKhbxQ7ylgQsea3aHhSYGyqjgy6Xgq55kBJffc
ARG YANDEX_SITE_VERIFICATION=

ENV NEXT_PUBLIC_API_BASE_URL=$NEXT_PUBLIC_API_BASE_URL
ENV NEXT_PUBLIC_SITE_URL=$NEXT_PUBLIC_SITE_URL
ENV NEXT_PUBLIC_GOOGLE_TAG_ID=$NEXT_PUBLIC_GOOGLE_TAG_ID
ENV GOOGLE_SITE_VERIFICATION=$GOOGLE_SITE_VERIFICATION
ENV YANDEX_SITE_VERIFICATION=$YANDEX_SITE_VERIFICATION

COPY package.json package-lock.json ./
RUN npm ci

COPY . .
RUN npm run build

EXPOSE 3000

CMD ["npm", "run", "start:docker"]
